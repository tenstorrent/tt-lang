 namespace mlir::tt::ttkernel {

+static LogicalResult verifyTridValue(Value trid, Operation *op) {
+  auto value = getConstantIntValue(trid);
+  if (!value) {
+    return success();
+  }
+
+  if (*value < 0 || *value > 15) {
+    return op->emitOpError("trid must be in [0, 15].");
+  }
+  return success();
+}
+
+static LogicalResult verifyOptionalNocValue(Value noc, Operation *op) {
+  if (!noc) {
+    if (op->getNumOperands() <= 1) {
+      return success();
+    }
+    noc = op->getOperand(1);
+  }
+
+  auto value = getConstantIntValue(noc);
+  if (!value) {
+    return success();
+  }
+
+  if (*value < 0 || *value > 1) {
+    return op->emitOpError("noc must be 0 or 1.");
+  }
+  return success();
+}
