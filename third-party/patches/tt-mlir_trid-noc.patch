+::mlir::LogicalResult NocAsyncReadSetTridOp::verify() {
+  if (failed(verifyTridValue(getTrid(), getOperation()))) {
+    return failure();
+  }
+  return verifyOptionalNocValue(getNoc(), getOperation());
+}
+
+::mlir::LogicalResult NocAsyncReadOnePacketWithStateWithTridOp::verify() {
